{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": [
      "ES2020"
    ],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "outDir": "../../../dist/src/skills/generated",
    "rootDir": ".",
    "moduleResolution": "node",
    "types": [
      "node"
    ]
  },
  "include": [
    "*.ts"
  ]
}
